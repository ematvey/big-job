#!/bin/sh
# big-job — Dispatcher for big-job subcommands.
#
# Usage: big-job <command> [args...]
#
# Commands: start, status, output, kill, list, wait, cleanup

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ "$#" -eq 0 ]; then
    echo "Usage: big-job <command> [args...]" >&2
    echo "Commands: start, status, output, kill, list, wait, cleanup" >&2
    exit 1
fi

CMD="$1"
shift

case "$CMD" in
    start|status|output|kill|list|wait|cleanup)
        exec "$SCRIPT_DIR/big-job-${CMD}.sh" "$@"
        ;;
    *)
        echo "Unknown command: $CMD" >&2
        echo "Commands: start, status, output, kill, list, wait, cleanup" >&2
        exit 1
        ;;
esac
